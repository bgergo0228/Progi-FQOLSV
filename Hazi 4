// KIIRATÁS
#include <stdio.h>
void kiir(int tomb[], int meret)
{
   for(int i = 0; i < meret; i++)
   {
       printf("%d", tomb[i]);
       if(i < meret-1) printf(", ");
   }
   printf("\n");
}

int main() {
    
    int T[7]={2, 4, 8, 3, 9, 7, 1};
    int meret = 7;
    kiir(T,meret);
    return 0;
}

//pozitív hozzáállás
#include <stdio.h>
#include <stdlib.h>

void csere(int tomb[], int meret)
{
    for(int i = 0; i < meret; i++)
    {
        if(tomb[i] < 0)
        {
            tomb[i] = abs(tomb[i]);
        }
    } 
}
void ir(int tomb[], int meret)
{
    for(int i =0; i< meret; i++)
    {
        printf("%d ", tomb[i]);
    }
    printf("\n");
}


int main()
{
    int T[6] = {74, -13, 47, -10, 4, -32};
    int meret = 6;
    ir(T, meret);
    csere(T, meret);       
    ir(T, meret);
    
    return 0;
}


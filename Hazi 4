// FELHŐKARCOLÓ
#include <stdio.h>
#include <stdlib.h>
int karcol(int tomb[], int meret)
{   
    int n = 0;
    for(int i =1; i<meret; i++)
    {
        n=n+abs(tomb[i] -tomb[i-1]);
    }
    return n;
}


int main() {
    
    int T[7]={2, 4, 8, 3, 9, 7, 1};
    int meret = 7;
    printf("\n%d", karcol(T, meret));
    return 0;
}




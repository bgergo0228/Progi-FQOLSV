// VALID TRIANGLE
#include <stdio.h>
int valid_triangle(float a, float b, float c)
{
    if(a+b>c && a+c>b && b+c>a) return 1;
    else return 0;
}

int main() {
    float a=0, b=0, c=0;
    printf("Add meg a 3szög oldalait: ");
    scanf("%f %f %f",&a, &b, &c);
    printf("%d", valid_triangle(a, b, c));
    
    return 0;
}


// ISEVEN ISODD
#include <stdio.h>
int is_even(int n)
{
    if(n%2==0) return 1;
    else return 0;
}
int is_odd(int n)
{
    if(n%2==0) return 0;
    else return 1;
}

int main() {
    int n = 1;
    printf("%d",is_even(n));
    
    return 0;
}


// RENDEZETT
#include <stdio.h>
int rendezett(int tomb[], int meret)
{
    int n = 1;
    for(int i =1; i< meret; i++)
    {
        if(tomb[i]<tomb[i-1]) n=0;
    }
    return n;
}

int main() {
    
    int T[5]={6, 45, 322, 344, 465};
    int meret = 5;
    printf("%d", rendezett(T, meret));
    
    return 0;
}

// Tömb legkisebb / legnagyobb eleme
#include <stdio.h>
int kicsi(int tomb[], int meret)
{   
    int n = tomb[0];
    for(int i =0; i<meret; i++)
    {
        if(tomb[i]<n) n=tomb[i];
    }
    return n;
}
int nagy(int tomb[], int meret)
{   
    int n = tomb[0];
    for(int i =0; i<meret; i++)
    {
        if(tomb[i]>n) n=tomb[i];
    }
    return n;
}

int main() {
    
    int T[5]={751, 45, 3242, 344, 465};
    int meret = 5;
    printf("\n%d", kicsi(T, meret));
    printf("\n%d", nagy(T, meret));
    return 0;
}


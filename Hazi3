//Fibonacci
#include <stdio.h>

double fibonacci(int n) {
    if (n <= 0) return 0;
    if (n == 1) return 0;
    if (n == 2) return 1;

    double a = 0;
    double b = 1;
    double c;

    
    for (int i = 3; i <= n; i++) {
        c = a+b;
        a = b;
        b = c;
    }
    
    return c;
}

int main() {
    
    for (int i = 1; i <= 100; i++) {
        printf("%d. >>> %.0lf\n", i, fibonacci(i));
    }

    return 0;
}


// Legnagyobb osztó
#include <stdio.h>

int oszto(int n) {
    if (n <= 1) return 1; 


    for(int i = 2; i <= n; i++) {
        if(n % i == 0) {
            return n / i;
        }
    }
    
    return 1;
}

int main() {
    
    for( int i = 1; i <=50; i++)
    {
    printf("%d >>> %d\n",i, oszto(i));
    }


    return 0;
}
